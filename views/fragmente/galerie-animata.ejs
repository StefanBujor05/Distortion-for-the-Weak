<div class="galerie-animata">
    <% for (let imag of locals.imaginiAnimata) { %>
        <figure>
            <picture>
                <source srcset="<%- imag.fisier_mediu %>" media="screen and (max-width:1100px)">
                <img src="<%- imag.fisier %>" alt="<%- imag.alt %>">
            </picture>
        </figure>
    <% } %>
</div>