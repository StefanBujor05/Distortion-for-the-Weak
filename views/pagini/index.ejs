    <section id="sectiune-formula">
        <h2>Fizica Sunetului: Unda sonora</h2>
        <p>O reprezentare matematică a sunetului pe care îl iubești:</p>
        
        <math xmlns="http://www.w3.org/1998/Math/MathML" class="formula-sunet" display="block">
            <mrow>
                <mi class="var-dependenta">y</mi>
                <mo class="paranteza">(</mo>
                <mi class="timp">t</mi>
                <mo class="paranteza">)</mo>
            </mrow>
            
            <mo class="operator-principal">=</mo>
            
            <mi class="amplitudine">A</mi>
            <mo class="inmultire">&sdot;</mo>
            
            <mi class="functie-trig">sin</mi>
            
            <mrow>
                <mo class="paranteza">(</mo>
                <mn class="numar">2</mn>
                <mi class="constanta">&pi;</mi>
                <mi class="frecventa">f</mi>
                <mi class="timp">t</mi>
                <mo class="operator-secundar">+</mo>
                <mi class="faza">&phi;</mi>
                <mo class="paranteza">)</mo>
            </mrow>
        </math>
