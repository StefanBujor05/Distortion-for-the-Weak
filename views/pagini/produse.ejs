<!DOCTYPE html>
<html  lang="ro">
    <head>
        <meta name="description" content="Distortion for the Weak">
        <meta name="keywords" content="metal, music, rock, album, produse">
        <link rel="stylesheet" href="/Resurse/css/produse.css" type="text/css" />
        <title>Disortion for the Weak - Produse</title>
        <%- include("../fragmente/head") %>     
        <script type="text/javascript" src=/Resurse/js/produse.js></script>
        <script type="text/javascript" src=/Resurse/js/produse-cos.js></script>

    </head>
    <body>


    <%- include("../fragmente/header") %>

    <main>
        <label> Nume: <input type="text" id="inp-nume"></label>
        <!--<label> Maxim calorii: <input type="number" id="inp-calorii" value="10000"></label>-->
        <div> Numar de piese:<!-- trebuie sa aiba acelasi name ca sa formeze un grup -->
            <p><label>Numar piese &le; 6 piese
                <input id="i_rad1"  name="gr_rad" value="1:6" type="radio"/>
            </label></p>
            <p><label>Numar piese 6-11 piese
                <input id="i_rad2"  name="gr_rad" value="6:11" type="radio"/>
            </label>
            <p><label>Numar piese &ge; 12 piese
                <input id="i_rad3" name="gr_rad" value="12:1000000000" type="radio"/>
            </label>
            <p><label>Toate
                <input id="i_rad4" checked name="gr_rad" value="toate" type="radio"/>
            </label>
        </div>


        <label> Pret minim: <input type="range" id="inp-pret" value="0" min="0"  max="70"> <span id="infoRange">(0)</span></label>
        <label>Select simplu:
            <select id="inp-categorie">
                <option id="sel-toate" selected value="toate">toate</option>
                <% for (let opt of locals.optiuni) { %>
                    <option value="<%- opt.unnest %>"><%- opt.unnest %> </option>
                <% } %>
            </select>
        </label>
        
        <label>Culoare Album: 
            <input type="text" id="inp-culoare" list="culoare-album">
            <datalist id="culoare-album">
                <option value="rosu">
                <option value="albstru">
                <option value="negru">
                <option value="mov">
                <option value="multi">
            </datalist>
        </label>

        <div>
            <input type="checkbox" id="livrare" name="livrare" value="false"/>
            <label for="livrare">Livrare</label>
        </div>

        <div>
            <textarea id="inp-membrii" name="inp-membrii" rows="3" cols="33">Membrii..</textarea>
        </div>

        <p>
            <button class="c1 c2 c3" id="filtrare">Filtreaza</button> 

            <button id="resetare">Reseteaza</button><br/>
            <button id="sortCrescNume">Sorteaza crescator dupa pret si nume</button>
            <button id="sortDescrescNume">Sorteaza descrescator dupa pret si nume</button>
        
        </p>
      
        <p id="p-suma">Apăsați Alt+"c" pentru suma preturilor produselor afișate. </p>
  
        <section id="produse">

            <h2>Produse</h2>
            <div class="grid-produse">
                <% for( let prod of locals.produse) { %>
                    <article class="produs" >
                        <h3 class="nume"><a href="/produs/<%-prod.id %>" ><span class="val-nume"><%- prod.nume%></span></a></h3>
                        <figure>
                            <a href="/produs/<%-prod.id %>" ><img src="/Resurse/imagini/produse/<%- prod.imagine %>" style="width:50%;height:auto;" alt="[imagine <%- prod.nume %>]" /></a>
                        </figure>
                        <div class="info-prod">
                            <p class="pret">Pret: <span class="val-pret"><%- prod.pret%></span></p>
                            <p class="nr-piese">Numar piese: <span class="val-nr-piese"><%- prod.numar_piese%></span></p>
                            <p class="format">Format: <span class="val-format"><%- prod.format%></span></p>
                            <p class="categorie">Categorie: <span class="val-categorie"><%- prod.categ_muzicala%></span></p>
                            <p class="culoare">Culoare: <span class="val-culoare"><%- prod.culoare%></span></p>
                            <p class="livrare">Livrare: <span class="val-livrare"><%- prod.livrare %></span></p>
                            <p class="membrii">Membrii: <span class="val-membrii"><%- prod.membrii %></span></p>
                        </div>
                        <label class="selecteaza-cos">
                            Selectează:<br/>
                            <input type="checkbox" class="select-cos" value="<%-prod.id %>" autocomplete="off">
                        </label>
                    </article>
                <% }%>
            </div>
        </section>
    </main>

    <%- include("../fragmente/footer") %>
    </body>
</html>