<!DOCTYPE html>
<html lang="ro">
    <head>
        <meta name="description" content="Distortion for the Weak">
        <meta name="keywords" content="metal, music, rock, album, produse">
        <link rel="stylesheet" href="/Resurse/css/produse.css" type="text/css" />
        <title>Disortion for the Weak - Produse</title>
        <%- include("../fragmente/head") %>     
        <script type="text/javascript" src="/Resurse/js/produse.js"></script>
        <script type="text/javascript" src="/Resurse/js/produse-cos.js"></script>
    </head>
    <body>

    <%- include("../fragmente/header") %>

    <main class="container my-5">
        <section id="filtre" class="mb-5 p-4 border rounded shadow-sm" style="background-color: rgba(0,0,0,0.2);">
            <div class="row g-4">
                
                <div class="col-12 col-md-6 col-lg-4">
                    <label class="form-label" for="inp-nume">Nume:</label>
                    <input type="text" id="inp-nume" class="form-control" placeholder="Cauta album...">
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <label class="form-label" for="inp-culoare">Culoare Album:</label>
                    <input class="form-control" list="culoare-album" id="inp-culoare" placeholder="Alege culoarea...">
                    <datalist id="culoare-album">
                        <option value="rosu">
                        <option value="albstru">
                        <option value="negru">
                        <option value="mov">
                        <option value="multi">
                    </datalist>
                </div>

                <div class="col-12 col-md-6 col-lg-4">
                    <label class="form-label" for="inp-categorie">Categorie:</label>
                    <select id="inp-categorie" class="form-select">
                        <option id="sel-toate" selected value="toate">toate</option>
                        <% for (let opt of locals.optiuni) { %>
                            <option value="<%- opt.unnest %>"><%- opt.unnest %></option>
                        <% } %>
                    </select>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label d-flex justify-content-between" for="inp-pret">
                        Pret minim: <span id="infoRange" class="badge bg-secondary">(0)</span>
                    </label>
                    <input type="range" class="form-range" id="inp-pret" value="0" min="0" max="70">
                </div>

                <div class="col-12 col-lg-6">
                    <label class="form-label d-block">Numar de piese:</label>
                    <div class="btn-group w-100 flex-wrap" role="group">
                        <input type="radio" class="btn-check" id="i_rad1" name="gr_rad" value="1:6" autocomplete="off">
                        <label class="btn btn-outline-primary" for="i_rad1">&le; 6 piese</label>

                        <input type="radio" class="btn-check" id="i_rad2" name="gr_rad" value="6:11" autocomplete="off">
                        <label class="btn btn-outline-primary" for="i_rad2">6-11 piese</label>

                        <input type="radio" class="btn-check" id="i_rad3" name="gr_rad" value="12:1000000000" autocomplete="off">
                        <label class="btn btn-outline-primary" for="i_rad3">&ge; 12 piese</label>

                        <input type="radio" class="btn-check" id="i_rad4" name="gr_rad" value="toate" autocomplete="off" checked>
                        <label class="btn btn-outline-primary" for="i_rad4">Toate</label>
                    </div>
                </div>

                <div class="col-12 col-md-4 d-flex align-items-center mt-4">
                    <input type="checkbox" class="btn-check" id="livrare" name="livrare" value="false" autocomplete="off">
                    <label class="btn btn-outline-secondary w-100" for="livrare">
                        <i class="bi bi-box-seam me-2"></i> Doar cu livrare
                    </label>
                </div>

                <div class="col-12">
                    <div class="form-floating text-dark">
                        <textarea class="form-control" placeholder="Tastează membrii trupei aici" id="inp-membrii" name="inp-membrii" style="height: 100px"></textarea>
                        <label for="inp-membrii">Caută membri (ex: Gerard Way, Ray Toro)</label>
                        <div class="invalid-feedback">
                            Textul introdus nu este valid.
                        </div>
                    </div>
                </div>

                <div class="col-12 mt-4 d-flex gap-2 flex-wrap justify-content-center">
                    <button class="btn btn-primary" id="filtrare">
                        <i class="bi bi-funnel-fill"></i> <span class="d-none d-md-inline">Filtreaza</span>
                    </button> 
                    <button class="btn btn-secondary" id="resetare">
                        <i class="bi bi-arrow-counterclockwise"></i> <span class="d-none d-md-inline">Reseteaza</span>
                    </button>
                    <button class="btn btn-primary" id="sortCrescNume">
                        <i class="bi bi-sort-alpha-down"></i> <span class="d-none d-md-inline">Sort. Ascendent</span>
                    </button>
                    <button class="btn btn-primary" id="sortDescrescNume">
                        <i class="bi bi-sort-alpha-up-alt"></i> <span class="d-none d-md-inline">Sort. Descendent</span>
                    </button>
                </div>

            </div>
        </section>

        <p id="p-suma" class="text-muted"><small><i class="bi bi-info-circle"></i> Apăsați Alt+"c" pentru suma preturilor produselor afișate.</small></p>

        <section id="produse">
            <h2 class="mb-4">Produse</h2>
            <div class="grid-produse">
                <% for( let prod of locals.produse) { %>
                    <article class="produs border rounded p-3 mb-3 shadow-sm" >
                        <h3 class="nume h5"><a href="/produs/<%-prod.id %>" class="text-decoration-none"><span class="val-nume"><%- prod.nume%></span></a></h3>
                        <figure class="text-center">
                            <a href="/produs/<%-prod.id %>" ><img src="/Resurse/imagini/produse/<%- prod.imagine %>" class="img-fluid rounded" style="width:50%;height:auto;" alt="[imagine <%- prod.nume %>]" /></a>
                        </figure>
                        <div class="info-prod small">
                            <p class="pret mb-1">Pret: <span class="val-pret fw-bold"><%- prod.pret%></span></p>
                            <p class="nr-piese mb-1">Numar piese: <span class="val-nr-piese"><%- prod.numar_piese%></span></p>
                            <p class="format mb-1">Format: <span class="val-format"><%- prod.format%></span></p>
                            <p class="categorie mb-1">Categorie: <span class="val-categorie"><%- prod.categ_muzicala%></span></p>
                            <p class="culoare mb-1">Culoare: <span class="val-culoare"><%- prod.culoare%></span></p>
                            <p class="livrare mb-1">Livrare: <span class="val-livrare"><%- prod.livrare %></span></p>
                            <p class="membrii text-truncate" title="<%- prod.membrii %>">Membrii: <span class="val-membrii"><%- prod.membrii %></span></p>
                        </div>
                        <label class="selecteaza-cos mt-2 d-block w-100 btn btn-sm btn-outline-secondary">
                            <i class="bi bi-cart-plus"></i> Selectează
                            <input type="checkbox" class="select-cos ms-1" value="<%-prod.id %>" autocomplete="off">
                        </label>
                    </article>
                <% }%>
            </div>
        </section>
    </main>

    <%- include("../fragmente/footer") %>
    </body>
</html>